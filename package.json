{
    "name": "software-foundry",
    "version": "0.1.0",
    "private": true,
    "description": "Personal knowledge base for growing as a Software Engineer.",
    "scripts": {
        "prepare": "husky",
        "commitlint:last": "commitlint --last --verbose",
        "commitlint:range": "commitlint --from HEAD~1 --to HEAD --verbose",
        "note": "node scripts/new-note.mjs",
        "changelog": "git-cliff -o CHANGELOG.md",
        "changelog:unreleased": "git-cliff --unreleased -o CHANGELOG.md",
        "site:build": "bash scripts/quartz.sh",
        "site:serve": "bash scripts/quartz.sh --serve",
        "site:clean": "rm -rf .cache/quartz public"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.1.0",
        "@commitlint/config-conventional": "^21.1.0",
        "husky": "^9.1.7"
    }
}
